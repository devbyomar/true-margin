# ============================================================
# TrueMargin — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ============================================================

# ============================================================
# Supabase — https://supabase.com/dashboard
# Project Settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=             # https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # sb_publishable_... (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=            # sb_secret_... (NEVER expose client-side)

# ============================================================
# Twilio — https://console.twilio.com
# Used for inbound/outbound SMS (field crew cost logging)
# ============================================================
TWILIO_ACCOUNT_SID=                   # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=                    # Found under Account Info on Twilio Console
TWILIO_PHONE_NUMBER=                  # E.164 format e.g. +14165550123

# ============================================================
# Stripe — https://dashboard.stripe.com/apikeys
# ============================================================
STRIPE_SECRET_KEY=                    # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=                # whsec_... (from Stripe webhook endpoint)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_live_... or pk_test_...
STRIPE_STARTER_PRICE_ID=              # price_... ($149 CAD/mo — Starter plan)
STRIPE_GROWTH_PRICE_ID=               # price_... ($349 CAD/mo — Growth plan)
STRIPE_SCALE_PRICE_ID=                # price_... ($699 CAD/mo — Scale plan)

# ============================================================
# Resend — https://resend.com/api-keys
# Used for transactional emails (team invites, notifications)
# ============================================================
RESEND_API_KEY=                       # re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=                    # e.g. noreply@truemargin.ca (must be a verified domain)

# ============================================================
# OpenAI — https://platform.openai.com/api-keys
# Used for GPT-4o Vision OCR invoice scanning (~$0.002/scan)
# ============================================================
OPENAI_API_KEY=                       # sk-...

# ============================================================
# App
# Change to your production URL when deploying to Vercel
# ============================================================
NEXT_PUBLIC_APP_URL=                  # http://localhost:3000 or https://app.truemargin.ca
